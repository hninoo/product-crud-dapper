<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Product CRUD</title>
    <script>
        (function () {
            var theme = localStorage.getItem("theme");
            if (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches) {
                theme = "dark";
            }
            if (theme) {
                document.documentElement.setAttribute("data-bs-theme", theme);
            }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-body border-bottom sticky-top mb-4">
        <div class="container">
            <a class="navbar-brand fw-semibold d-flex align-items-center gap-2"
               asp-controller="Products" asp-action="Index">
                <span class="brand-mark" aria-hidden="true">P</span> Product CRUD
            </a>
            <div class="d-flex align-items-center">
                <div class="navbar-nav flex-row gap-1">
                    <a class="nav-link px-2" asp-controller="Products" asp-action="Index">Products</a>
                    <a class="nav-link px-2" asp-controller="Products" asp-action="Create">Add Product</a>
                </div>
                <button id="themeToggle" type="button" class="btn btn-outline-secondary btn-sm ms-3"
                        aria-label="Toggle light and dark theme">
                    <span class="theme-icon-moon" aria-hidden="true">&#127769;</span>
                    <span class="theme-icon-sun" aria-hidden="true">&#9728;&#65039;</span>
                </button>
            </div>
        </div>
    </nav>

    <main class="container pb-5">
        @if (TempData["SuccessMessage"] is string message)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @message
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(function () {
            // Success messages confirm and get out of the way after a few seconds.
            setTimeout(function () {
                $('.alert-success .btn-close').trigger('click');
            }, 4000);

            
            $('#themeToggle').on('click', function () {
                var html = document.documentElement;
                var next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-bs-theme', next);
                localStorage.setItem('theme', next);
            });

    
            $('#deleteProductModal')
                .on('show.bs.modal', function (event) {
                    var button = $(event.relatedTarget);
                    $('#deleteProductId').val(button.data('product-id'));
                    $('#deleteProductName').text(button.data('product-name'));
                    $('#deleteProductPrice').text(button.data('product-price'));
                })
                .on('shown.bs.modal', function () {
                    $(this).find('.modal-footer .btn-outline-secondary').trigger('focus');
                });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
